<?xml version="1.0" encoding="utf-8"?>
<!--
    Brahman Browser — activity_main.xml
    Phase 2: Browser skeleton root layout

    Stack (top→bottom):
      1. Gradient background
      2. AddressBarView      (56 dp, top)
      3. Content frame       (flex, holds new-tab page + overlays)
         ├─ NewTab page      (placeholder)
         ├─ DownloadOverlay  (centre, glass panel 300 dp)
         └─ FloatingPlayer   (200×120 dp, draggable)
      4. Demo button bar     (bottom, dev-only)
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/rootLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_deep_ocean"
    tools:context=".MainActivity">

    <!-- ══ BACKGROUND GRADIENT ══ -->
    <View
        android:id="@+id/viewBgGradient"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@drawable/bg_main_gradient"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ══ 1. ADDRESS BAR — 56 dp, full width ══ -->
    <com.brahman.browser.ui.addressbar.AddressBarView
        android:id="@+id/addressBar"
        android:layout_width="0dp"
        android:layout_height="@dimen/address_bar_height"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ══ 2. CONTENT FRAME — fills remaining height ══ -->
    <FrameLayout
        android:id="@+id/contentFrame"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/addressBar"
        app:layout_constraintBottom_toTopOf="@id/demoBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- ── 2a. NEW TAB PAGE (placeholder) ── -->
        <include
            android:id="@+id/layoutNewTabPage"
            layout="@layout/layout_new_tab_page"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <!-- ── 2b. DOWNLOAD OVERLAY — 300 dp wide, centred ── -->
        <com.brahman.browser.ui.download.DownloadOverlayView
            android:id="@+id/downloadOverlay"
            android:layout_width="@dimen/download_overlay_width"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:visibility="gone"
            tools:visibility="visible" />

        <!-- ── 2c. FLOATING PLAYER — 200×120 dp, bottom-right ── -->
        <com.brahman.browser.ui.player.FloatingPlayerView
            android:id="@+id/floatingPlayer"
            android:layout_width="@dimen/floating_player_width"
            android:layout_height="@dimen/floating_player_height"
            android:layout_gravity="bottom|end"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="16dp"
            android:visibility="gone"
            tools:visibility="visible" />

    </FrameLayout>

    <!-- ══ 3. DEMO BUTTON BAR (Phase 2 testing only) ══ -->
    <LinearLayout
        android:id="@+id/demoBar"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="8dp"
        android:spacing="8dp"
        android:background="@color/bg_status_bar"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="DEMO →"
            android:textSize="9sp"
            android:textColor="@color/text_muted"
            android:fontFamily="monospace"
            android:letterSpacing="0.12" />

        <!-- Download overlay trigger -->
        <Button
            android:id="@+id/btnDemoDownload"
            style="@style/Widget.Brahman.DemoButton"
            android:text="⬇ Download"
            android:layout_marginEnd="8dp" />

        <!-- Floating player trigger -->
        <Button
            android:id="@+id/btnDemoPlayer"
            style="@style/Widget.Brahman.DemoButton"
            android:text="▶ Player" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>